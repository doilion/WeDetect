# Work directories (training outputs, ~50GB)
work_dirs/

# Dataset (raw patient data — never commit)
# Use data/* + negate pattern to allow re-including data/texts/
data/*
# Allow text prompt JSONs + derived embedding caches (no PHI, needed for paper reproduction)
!data/texts/

# Block any .pth/.pt model weights anywhere EXCEPT data/texts/ (those are small derived caches)
*.pt
# global *.pth excluded so checkpoints/ catches model files; data/texts/.pth is allowed by negation
**/checkpoint_*.pth
**/epoch_*.pth
**/best_*.pth
**/last.pth

# XLM-Roberta model files
xlm-roberta-base/

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# OS files
.DS_Store
Thumbs.db

# Stray markers from external tools
.codex

# Claude Code agent state and local IDE config
.claude/

# Claude Code project instructions (contain dev environment paths)
CLAUDE.md
AGENTS.md

# Paper drafts — contain author identity (BibM double-blind review)
paper/
